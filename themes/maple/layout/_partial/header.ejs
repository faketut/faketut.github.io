<header class="fixed w-full px-5 py-1 z-10 backdrop-blur-xl backdrop-saturate-150 border-b border-black/5">
  <div class="max-auto">
    <nav class="flex items-center text-base">
      <a href="<%- config.root %>" class="group">
        <h2 class="font-medium tracking-tighterp text-l p-2">
          <img class="w-5 mr-2 inline-block transition-transform group-hover:rotate-[30deg]" id="logo" src="<%- theme.logo %>" alt="<%- config.title %>" />
          <%= config.title %>
        </h2>
      </a>
      <div id="header-title" class="opacity-0 md:ml-2 md:mt-[0.1rem] text-xs font-medium whitespace-nowrap overflow-hidden overflow-ellipsis">
        <%- page.title %>
      </div>
      <div class="flex-1"></div>
      <div class="flex items-center gap-3">
        <% for (var i in theme.nav){ %>
          <%
            var navPath = theme.nav[i];
            var isExternal = typeof navPath === 'string' && (navPath.indexOf('http://') === 0 || navPath.indexOf('https://') === 0);
            var langPrefix = (currentLang === 'en' || currentLang === 'zh-CN') ? ('/' + currentLang) : '';
            var navHref = isExternal ? navPath : url_for(langPrefix + navPath);
          %>
          <a class="hidden sm:flex" href="<%- navHref %>"><%= __(i) %></a>
        <% } %>
        <%
          var currentLang = (page && page.lang) ? page.lang : (config.language || 'en');
          if (Array.isArray(currentLang)) currentLang = currentLang[0];
          currentLang = (currentLang + '').split(',')[0].trim();
          var targetLang = currentLang === 'zh-CN' ? 'en' : 'zh-CN';
          var currentPath = page && page.path ? page.path : '';
          var targetPath = currentPath.startsWith(currentLang + '/')
            ? (targetLang + '/' + currentPath.slice((currentLang + '/').length))
            : (targetLang + '/');
          var switchHref = url_for('/' + targetPath);
        %>
        <a class="hidden sm:flex text-sm font-medium opacity-80 hover:opacity-100" title="Switch language" href="<%- switchHref %>">
          <%= currentLang === 'zh-CN' ? 'EN' : '中文' %>
        </a>
        <% if (theme.links !== undefined) { %>
          <% for (var key in theme.links) { %>
            <a class="w-5 h-5 hidden sm:flex" title="<%- key %>" href="<%= theme.links[key] %>">
              <iconify-icon width="20" icon="ri:<%- key.toLowerCase() %>-line"></iconify-icon>
            </a>
          <% } %>
        <% } %>
        <a class="w-5 h-5 hidden sm:flex" title="RSS" href="<%- url_for('/rss2.xml') %>" target="_blank" rel="noopener noreferrer">
          <iconify-icon width="20" icon="ri:rss-line"></iconify-icon>
        </a>
        <a class="w-5 h-5" title="toggle theme" id="toggle-dark">
          <iconify-icon width="20" icon="" id="theme-icon"></iconify-icon>
        </a>
      </div>
      <div class="flex items-center justify-center gap-3 ml-3 sm:hidden">
        <span class="w-5 h-5" aria-hidden="true" role="img" id="open-menu">
          <iconify-icon width="20" icon="carbon:menu" ></iconify-icon>
        </span>
        <span class="w-5 h-5 hidden" aria-hidden="true" role="img" id="close-menu">
          <iconify-icon  width="20" icon="carbon:close" ></iconify-icon>
        </span>
      </div>
    </nav>
  </div>
</header>
<div id="menu-panel" class="h-0 overflow-hidden sm:hidden fixed left-0 right-0 top-12 bottom-0 z-10">
  <div id="menu-content" class="relative z-20 bg-white/80 px-6 sm:px-8 py-2 backdrop-blur-xl -translate-y-full transition-transform duration-300">
    <ul class="nav flex flex-col sm:flex-row text-sm font-medium">
      <% for (var i in theme.nav){ %>
        <li class="nav-portfolio sm:mx-2 border-b sm:border-0 border-black/5 last:border-0 hover:text-main">
          <%
            var navPathM = theme.nav[i];
            var isExternalM = typeof navPathM === 'string' && (navPathM.indexOf('http://') === 0 || navPathM.indexOf('https://') === 0);
            var langPrefixM = (currentLang === 'en' || currentLang === 'zh-CN') ? ('/' + currentLang) : '';
            var navHrefM = isExternalM ? navPathM : url_for(langPrefixM + navPathM);
          %>
          <a href="<%- navHrefM %>" class="flex h-12 sm:h-auto items-center"><%= __(i) %></a>
        </li>
      <% } %>
      <li class="nav-portfolio sm:mx-2 border-b sm:border-0 border-black/5 last:border-0 hover:text-main">
        <a href="<%- switchHref %>" class="flex h-12 sm:h-auto items-center">
          <%= currentLang === 'zh-CN' ? 'EN' : '中文' %>
        </a>
      </li>
    </ul>
  </div>
  <div class="mask bg-black/20 absolute inset-0"></div>
</div>
