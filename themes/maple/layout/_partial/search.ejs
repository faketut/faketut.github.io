<div id="search-modal" class="hidden fixed inset-0 z-50 flex items-start justify-center pt-20 px-4" aria-hidden="true" role="dialog" aria-label="Search">
  <div class="relative bg-white dark:bg-zinc-800 rounded-xl shadow-2xl w-full max-w-xl border border-gray-200 dark:border-zinc-700">
    <div class="flex items-center border-b border-gray-200 dark:border-zinc-700 px-4">
      <iconify-icon width="18" icon="ri:search-line" class="text-gray-400 shrink-0"></iconify-icon>
      <input
        id="search-input"
        type="text"
        placeholder="Search posts..."
        class="flex-1 px-3 py-4 bg-transparent outline-none text-sm dark:text-gray-100 placeholder-gray-400"
        autocomplete="off"
        spellcheck="false"
      />
      <button id="close-search" class="text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 shrink-0 p-1" aria-label="Close search">
        <iconify-icon width="18" icon="ri:close-line"></iconify-icon>
      </button>
    </div>
    <div id="search-results" class="max-h-80 overflow-y-auto py-2 text-sm empty:hidden"></div>
  </div>
  <div id="search-backdrop" class="absolute inset-0 bg-black/40 -z-10"></div>
</div>
